<style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: Arial, sans-serif; }
    body { background: #f4f4f4; color: #333; line-height: 1.6; }
    header { background: #0066cc; color: white; padding: 30px 20px; text-align: center; }
    nav ul { list-style: none; display: flex; justify-content: center; flex-wrap: wrap; margin-top: 10px; }
    nav ul li { margin: 0 15px; }
